# Hostname that Caddy will serve (must match your Cloudflare DNS A record)
TUNEBOSS_HOSTNAME=tuneboss.example.com

# Cloudflare API token with Zone:DNS:Edit permission for the zone above.
# Create one at: https://dash.cloudflare.com/profile/api-tokens
# Use the "Edit zone DNS" template, scoped to the specific zone.
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# Port the Node.js app listens on (must match PORT in tuneboss .env)
TUNEBOSS_PORT=3000
